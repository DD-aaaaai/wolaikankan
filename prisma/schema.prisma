generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String    @id @default(cuid())
  secondmeId     String    @unique
  name           String?
  avatar         String?
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  avatarProfile AvatarProfile?
  dailyFeeds    DailyFeed[]
}

model AvatarProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  avatarName  String?
  personality String?
  occupation  String?
  goal        String?
  story       String?
  slogan      String?
  setupDone   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DailyFeed {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      String
  content   String
  createdAt DateTime @default(now())

  @@unique([userId, date])
}
